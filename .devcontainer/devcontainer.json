{
  "name": "Dev Container Example",
  "image": "jbayer/devcontainer-flox:1.13.0@sha256:3661f9d8062a25a830fe2718e7bd8babbfcb911eaf0e33fb87ea351ced028952",
  "features": {
      },
  "customizations": {
    "vscode": {
      "extensions": [
        "flox.flox",
        "ms-vscode-remote.remote-containers"
      ]
    }
  },
  "appPort": ["8233:8233"],
  "mounts": [
    "source=/run/host-services/ssh-auth.sock,target=/run/host-services/ssh-auth.sock,type=bind",
    "source=${localEnv:HOME}/.gitconfig,target=/home/flox/.gitconfig,type=bind,readonly",
    "source=${localEnv:HOME}/.ssh,target=/home/flox/.ssh,type=bind,readonly",
    "source=devcontainer-nix-store-multiuser,target=/nix,type=volume",
    "source=${localWorkspaceFolderBasename}-flox-home,target=/home/flox,type=volume"
  ],
  "remoteEnv": {
    "SSH_AUTH_SOCK": "/run/host-services/ssh-auth.sock",
    "FLOX_AUTOACTIVATE_DIR": "${containerWorkspaceFolder}"
  },
  "postStartCommand": "sudo /usr/local/bin/fix-home-perms.sh && sudo /usr/local/bin/start-nix-daemon.sh",
  "remoteUser": "flox"
}
