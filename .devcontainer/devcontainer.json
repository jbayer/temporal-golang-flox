{
  "name": "Dev Container Example",
  "image": "jbayer/devcontainer-flox:1.12.1@sha256:f6412335b8878983fab01d6da3bc1375497b6b2955be1a4465b153997dd37ffd",
  "features": {
      },
  "customizations": {
    "vscode": {
      "extensions": [
        "flox.flox",
        "ms-vscode-remote.remote-containers"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.ssh,target=${localEnv:HOME}/.ssh,type=bind,readonly",
    "source=${localWorkspaceFolderBasename}-nix-store,target=/nix,type=volume",
    "source=${localWorkspaceFolderBasename}-floxuser-home,target=/home/floxuser,type=volume"
  ],
  "postStartCommand": "",
  "remoteUser": "floxuser"
}
